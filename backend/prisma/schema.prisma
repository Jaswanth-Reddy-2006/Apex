datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid()) @map("_id") 
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  Profile    Profile?

  @@map("users")
}

model Profile {
  id         String   @id @default(uuid()) @map("_id") 
  user_id    String   @unique 
  user       User     @relation(fields: [user_id], references: [id])
  email      String
  full_name  String?
  avatar_url String?
  headline   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("profiles")
}

model Organization {
  id             String   @id @default(uuid()) @map("_id") 
  name           String
  slug           String
  description    String?
  logo_url       String?
  domain         String?
  industry       String?
  employee_count String?
  country        String?
  timezone       String?
  phone          String?
  owner_id       String   
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("organizations")
}

model OrganizationMember {
  id              String   @id @default(uuid()) @map("_id") 
  organization_id String   
  user_id         String   
  role            String
  status          String
  phone           String?
  designation     String?
  department      String?
  custom_role_id  String?  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("organization_members")
}

model Workspace {
  id              String   @id @default(uuid()) @map("_id") 
  organization_id String   
  name            String
  slug            String
  description     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("workspaces")
}

model Project {
  id              String   @id @default(uuid()) @map("_id") 
  organization_id String   
  workspace_id    String?  
  name            String
  slug            String
  description     String?
  status          String
  repository_url  String?
  created_by      String   
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("projects")
}

model ProjectMember {
  id         String   @id @default(uuid()) @map("_id") 
  project_id String   
  user_id    String   
  role       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("project_members")
}

model Invitation {
  id              String   @id @default(uuid()) @map("_id") 
  organization_id String   
  email           String
  role            String
  status          String
  created_at      DateTime @default(now())
  expires_at      DateTime
  token           String   @unique

  @@map("invitations")
}

model Role {
  id              String   @id @default(uuid()) @map("_id") 
  organization_id String?  
  name            String
  description     String?
  is_system       Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @map("_id") 
  key         String
  name        String?
  description String?
  category    String
  created_at  DateTime @default(now())

  @@map("permissions")
}

model RolePermission {
  id            String   @id @default(uuid()) @map("_id") 
  role_id       String   
  permission_id String   
  created_at    DateTime @default(now())

  @@map("role_permissions")
}

model UserRole {
  id              String   @id @default(uuid()) @map("_id") 
  user_id         String   
  role_id         String   
  organization_id String   
  created_at      DateTime @default(now())

  @@map("user_roles")
}

model ChatConversation {
  id              String   @id @default(uuid()) @map("_id")
  project_id      String
  organization_id String
  user_id         String
  title           String
  pinned          Boolean  @default(false)
  archived        Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  last_message_at DateTime @default(now())

  @@map("chat_conversations")
}

model ChatMessage {
  id              String   @id @default(uuid()) @map("_id") 
  conversation_id String   
  project_id      String   
  user_id         String   
  role            String
  content         String
  attachments     Json?
  created_at      DateTime @default(now())
  model           String?

  @@map("chat_messages")
}

model ChatUpload {
  id              String   @id @default(uuid()) @map("_id") 
  conversation_id String   
  file_name       String
  file_path       String
  file_size       Int
  mime_type       String
  created_at      DateTime @default(now())
  user_id         String   

  @@map("chat_uploads")
}

model Document {
  id         String   @id @default(uuid()) @map("_id") 
  project_id String   
  title      String
  content    String?
  metadata   Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("documents")
}

model KnowledgeSource {
  id         String   @id @default(uuid()) @map("_id") 
  project_id String   
  name       String
  type       String
  config     Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("knowledge_sources")
}

model Notification {
  id         String   @id @default(uuid()) @map("_id") 
  user_id    String   
  title      String
  body       String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("notifications")
}

model AuditLog {
  id              String   @id @default(uuid()) @map("_id") 
  action          String
  created_at      DateTime @default(now())
  metadata        Json?
  organization_id String?  
  user_id         String?  

  @@map("audit_logs")
}

model ActivityLog {
  id          String   @id @default(uuid()) @map("_id") 
  action      String
  target_type String
  created_at  DateTime @default(now())
  metadata    Json?
  user_id     String?  

  @@map("activity_logs")
}

model ApiKey {
  id              String   @id @default(uuid()) @map("_id") 
  created_at      DateTime @default(now())
  key_hash        String
  name            String
  organization_id String   
  scopes          Json?
  user_id         String   

  @@map("api_keys")
}

model IntegrationConnection {
  id                    String   @id @default(uuid()) @map("_id")
  organization_id       String
  provider              String
  display_name          String?
  status                String
  metadata              Json?
  connected_by          String?
  last_sync_at          DateTime?
  credentials_vault_key String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@unique([organization_id, provider])
  @@map("integration_connections")
}

model IntegrationDataNode {
  id              String   @id @default(uuid()) @map("_id")
  organization_id String
  project_id      String
  provider        String   // e.g., "github", "vercel"
  content         String   // The text summary (e.g., PR title, deployment status)
  embedding       Float[]  // 384-dimensional vector from MiniLM
  created_at      DateTime @default(now())
  
  @@map("integration_data_nodes")
}
