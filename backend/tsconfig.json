{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tanstack/react-router": ["./src/shims/react-router.ts"],
      "@tanstack/react-start": ["./src/shims/react-start.ts"],
      "@tanstack/react-start/server": ["./src/shims/react-start-server.ts"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
